<!DOCTYPE html>
<html lang="en">
  <head>
    <%# "agents" reads bare in the header, where the page disambiguates it
        visually. In <title> and meta there is no visual context and a cold
        reader might think real-estate agent, so those say "AI agents". %>
    <% page_title = content_for(:title) || "Printwright — the 3D model store for AI agents" %>
    <% page_description = content_for(:description) || "Licensed 3D-printable models an AI agent, print server, or person can buy over plain HTTP. Pay in HBAR or USDC on Hedera; every purchase mints a verifiable certificate." %>
    <% social_image = content_for(:social_image) || "#{request.base_url}/og-printwright.png" %>
    <% social_image_alt = content_for(:social_image_alt) || "Printwright — the 3D model store for agents. Rights anchored on Hedera." %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="Printwright">
    <meta name="description" content="<%= page_description %>">
    <meta name="theme-color" content="#1B5E45">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Printwright">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:url" content="<%= request.base_url + request.path %>">
    <meta property="og:image" content="<%= social_image %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="<%= social_image_alt %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= social_image %>">
    <link rel="canonical" href="<%= request.base_url + request.path %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= javascript_tag nonce: true do %>
      (() => {
        try {
          const theme = localStorage.getItem("printwright-theme")
          if (theme === "light" || theme === "dark") document.documentElement.dataset.theme = theme
        } catch (_error) {}
      })()
    <% end %>

    <%= yield :head %>

    <link rel="preload" href="<%= asset_path("archivo-variable.woff2") %>"
          as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="<%= asset_path("ibm-plex-mono-600.woff2") %>"
          as="font" type="font/woff2" crossorigin>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">
    <link rel="manifest" href="/manifest.json">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <% wallet_project_id = ENV["WALLETCONNECT_PROJECT_ID"].presence %>
  <body<% if wallet_project_id %> data-controller="wallet-loader"
    data-wallet-loader-module-url-value="<%= asset_path("hedera_wallet.js") %>"<% end %>>
    <%# The contour ground. Fixed, non-interactive, one per page. %>
    <canvas id="ground-tex" aria-hidden="true" data-controller="texture"></canvas>

    <header class="site-header" data-controller="sticky-header">
      <div class="container">
        <%= link_to root_path, class: "wordmark" do %>
          <%= render "shared/brand_mark", size: 40 %>
          <span class="wordmark-copy">
            <span class="wordmark-name">Printwright</span>
            <span class="tagline">3D model store for agents.</span>
          </span>
        <% end %>
        <div class="catalog-search" data-controller="catalog-search"
             data-catalog-search-url-value="<%= search_suggestions_path %>"
             data-action="click@window->catalog-search#dismiss keydown->catalog-search#navigate">
          <%= form_with url: root_path(anchor: "models"), method: :get, class: "search-form",
                role: "search", data: { action: "submit->catalog-search#submit" } do %>
            <label class="visually-hidden" for="catalog_search_input">Search the model catalog</label>
            <input id="catalog_search_input" type="search" name="q" value="<%= params[:q] %>"
                   placeholder="Search models — try ‘beaver’" autocomplete="off" spellcheck="false"
                   role="combobox" aria-autocomplete="list" aria-expanded="false"
                   aria-controls="catalog_search_suggestions"
                   data-catalog-search-target="input"
                   data-action="input->catalog-search#queue keydown->catalog-search#keydown">
            <button class="search-clear" type="button" aria-label="Clear search"
                    data-catalog-search-target="clear" data-action="catalog-search#clear"
                    <%= "hidden" if params[:q].blank? %>>×</button>
            <button class="btn" type="submit">Search</button>
          <% end %>
          <%= turbo_frame_tag "catalog_search_suggestions", class: "search-suggestions",
                hidden: true, data: { catalog_search_target: "results",
                                     action: "turbo:frame-load->catalog-search#loaded" } %>
        </div>
        <nav class="header-actions t-small" aria-label="Account and wallet">
          <% cart_count = storefront_cart_count %>
          <%= link_to cart_count.positive? ? "Cart (#{cart_count})" : "Cart", cart_path,
                data: { cart_link: true } %>
          <%= link_to "My library", new_license_library_path %>
          <% if authenticated? %>
            <%= link_to "Dashboard", designer_models_path %>
          <% else %>
            <%= link_to "For designers", rodauth.login_path %>
          <% end %>
          <% if wallet_project_id %>
            <span class="wallet-control" data-hedera-wallet
                  data-project-id="<%= wallet_project_id %>"
                  data-network="<%= Hedera::Network.name %>" data-connected="false">
              <button class="linklike wallet-account" type="button" data-wallet-connect
                      data-action="wallet-loader#connectWallet">Connect wallet</button>
              <button class="linklike wallet-disconnect" type="button" data-wallet-disconnect
                      data-action="wallet-loader#disconnectWallet" hidden>Disconnect</button>
            </span>
          <% end %>
          <button type="button" class="theme-toggle" data-controller="theme"
                  data-action="theme#toggle" data-theme-target="button"
                  aria-label="Switch to dark mode" aria-pressed="false">Dark mode</button>
        </nav>
      </div>
    </header>

    <main class="container">
      <% if notice %>
        <div class="flash flash-ok"><%= render "shared/state_mark", state: "settled" %><span><%= notice %></span></div>
      <% end %>
      <% if alert %>
        <div class="flash flash-bad"><%= render "shared/state_mark", state: "void" %><span><%= alert %></span></div>
      <% end %>
      <%= content_for?(:content) ? yield(:content) : yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        License certificates anchor to Hedera Consensus Service topic
        <a class="mono" href="<%= Hedera::Network.hashscan_base %>/topic/<%= ENV.fetch("HEDERA_HCS_TOPIC_ID", "0.0.9585069") %>"><%= ENV.fetch("HEDERA_HCS_TOPIC_ID", "0.0.9585069") %></a>
        — publicly verifiable on the mirror node. Payments via x402 (Hedera <%= Hedera::Network.name %>, HBAR/USDC).
        <span class="footer-links t-small">
          <%= link_to "About", about_path %> · <%= link_to "Pricing", pricing_path %> ·
          <%= link_to "Terms", terms_path %> · <%= link_to "Privacy", privacy_path %> ·
          <%= link_to "Takedown", takedown_path %> · <%= link_to "API docs", docs_path %> ·
          <%= link_to "Open books", open_books_path %> ·
          <%= link_to "Chaos log", chaos_log_path %> ·
          <%= link_to "License library", new_license_library_path %> ·
          <%= link_to "License texts", license_document_path(version: "v1", kind: "personal") %> ·
          <%= link_to "Ask the shopkeeper", chat_path %>
        </span>
      </div>
    </footer>
  </body>
</html>
