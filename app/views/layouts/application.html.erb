<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Printwright — every print, licensed" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="Printwright">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <%= link_to root_path, class: "wordmark" do %>
          Printwright ⬡
          <span class="tagline">Every print, licensed.</span>
        <% end %>
        <%= form_with url: root_path, method: :get, class: "search-form" do %>
          <input type="search" name="q" value="<%= params[:q] %>" placeholder="Search models — try 'beaver'"
                 aria-label="Search models">
          <button class="btn" type="submit">Search</button>
        <% end %>
        <%= link_to "For designers", new_session_path, class: "t-small" %>
      </div>
    </header>

    <main class="container">
      <%= content_for?(:content) ? yield(:content) : yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        License certificates anchor to Hedera Consensus Service topic
        <a class="mono" href="<%= Hedera::Network.hashscan_base %>/topic/<%= ENV.fetch("HEDERA_HCS_TOPIC_ID", "0.0.9585069") %>"><%= ENV.fetch("HEDERA_HCS_TOPIC_ID", "0.0.9585069") %></a>
        — publicly verifiable on the mirror node. Payments via x402 (Hedera <%= Hedera::Network.name %>, HBAR/USDC).
        <span class="t-small" style="display:block; margin-top: var(--s-1)">
          <%= link_to "Terms", terms_path %> · <%= link_to "Privacy", privacy_path %> ·
          <%= link_to "Takedown", takedown_path %> ·
          <%= link_to "License texts", license_document_path(version: "v1", kind: "personal") %>
        </span>
      </div>
    </footer>
  </body>
</html>
