<% if ENV["GITHUB_CLIENT_ID"].present? || ENV["GOOGLE_CLIENT_ID"].present? %>
  <div class="oauth-buttons">
    <p class="t-caption muted">Or continue with</p>
    <% if ENV["GITHUB_CLIENT_ID"].present? %>
      <%= button_to "GitHub", rodauth.omniauth_request_path(:github),
            method: :post, data: { turbo: false }, class: "btn" %>
    <% end %>
    <% if ENV["GOOGLE_CLIENT_ID"].present? %>
      <%= button_to "Google", rodauth.omniauth_request_path(:google_oauth2),
            method: :post, data: { turbo: false }, class: "btn" %>
    <% end %>
  </div>
<% end %>
