<% content_for :title, "Sales — Printwright designer" %>
<h1>Sales</h1>
<% if @purchases.any? %>
  <table class="facts-table" style="width:100%">
    <tr><th>date</th><th>model</th><th>license</th><th>serial</th><th>amount</th><th>tx</th><th>cert</th></tr>
    <% @purchases.each do |purchase| %>
      <tr>
        <td class="t-small"><%= purchase.created_at.strftime("%b %-d %H:%M") %></td>
        <td><%= purchase.license_offer.model3d.title %></td>
        <td><%= purchase.license_offer.kind %></td>
        <td class="mono">#<%= purchase.license&.serial %></td>
        <td class="price">$<%= format("%.2f", purchase.license_offer.price_cents / 100.0) %></td>
        <td><a class="mono" href="https://hashscan.io/testnet/transaction/<%= purchase.payment_tx_id %>"><%= purchase.payment_tx_id&.truncate(22) %></a></td>
        <td><%= link_to purchase.license&.cert_id, verify_path(purchase.license.verify_slug), class: "mono" if purchase.license %></td>
      </tr>
    <% end %>
  </table>
<% else %>
  <div class="empty-state"><p>No sales yet. Published models are instantly buyable by agents via the API.</p></div>
<% end %>
