<% content_for :title, "Add webhook — Printwright designer" %>
<h1>Add webhook endpoint</h1>
<p class="muted">The destination must be public HTTPS. Its signing secret is shown once after creation.</p>

<%= form_with model: @endpoint, url: designer_webhook_endpoints_path do |form| %>
  <% if @endpoint.errors.any? %>
    <div class="flash flash-bad"><%= @endpoint.errors.full_messages.to_sentence %></div>
  <% end %>
  <div class="field">
    <%= form.label :url, "Callback URL" %>
    <%= form.url_field :url, required: true, placeholder: "https://hooks.example/printwright" %>
  </div>
  <%= form.submit "Create webhook" %>
<% end %>
