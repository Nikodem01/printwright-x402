<% page_title = if @catalog_definition
    "#{@catalog_definition.fetch(:name)} — Printwright"
  elsif @query.present?
    "#{@query} — Printwright"
  else
    "Printwright — the 3D model store for AI agents"
  end %>
<% content_for :title, page_title %>
<% content_for :description, @catalog_definition.fetch(:description) if @catalog_definition %>

<section class="hero<%= " hero-compact" if @catalog_definition %>">
  <% if @catalog_definition %>
    <p class="t-caption muted">Curated catalog</p>
    <h1><%= @catalog_definition.fetch(:name) %></h1>
    <p class="muted"><%= @catalog_definition.fetch(:description) %></p>
  <% else %>
    <%# The line claims a shelf rather than describing an attribute. Rights
        move from headline to proof: the licence claim lives one line down,
        where it is evidence for the promise instead of the promise. %>
    <div class="hero-copy">
      <h1>The 3D model store for agents.</h1>
      <p>Agents, print servers, and people — all buying over the same endpoint.
        No account, no card, no API key. Every purchase mints a certificate
        anyone can check.</p>
    </div>
    <section class="hero-shopkeeper" aria-labelledby="hero_shopkeeper_title" data-controller="chat-prompt">
      <div class="hero-shopkeeper-head">
        <div>
          <p class="eyebrow">Live catalog · human approval</p>
          <h2 id="hero_shopkeeper_title">Ask the shopkeeper</h2>
        </div>
        <div class="hero-shopkeeper-actions t-caption">
          <%= button_to "Reset chat", chat_path, method: :delete, class: "linklike" %>
          <%= link_to "Open full chat →", chat_path %>
        </div>
      </div>
      <div id="chat_messages" class="chat-messages hero-chat-messages" aria-live="polite"
           data-controller="chat-scroll">
        <% if @turns.empty? %>
          <div id="chat_empty_state" class="empty-state">
            <p class="t-small">Describe what you need. Every answer shows the real catalog tool call behind it.</p>
            <div class="chat-prompts" aria-label="Try a prompt">
              <button type="button" class="prompt-chip" data-action="chat-prompt#choose"
                      data-chat-prompt-message-param="Find something to tidy the cables on my desk.">
                Find a cable organizer
              </button>
              <button type="button" class="prompt-chip" data-action="chat-prompt#choose"
                      data-chat-prompt-message-param="Find a cable organizer under 3 USDC and help me buy a personal license.">
                Help me buy with AI
              </button>
            </div>
          </div>
        <% end %>
        <%= render partial: "chat/turn", collection: @turns, as: :turn %>
      </div>
      <%= render "chat/purchase", proposal: @purchase_proposal %>
      <%= render "chat/form", autofocus: false %>
      <p class="hero-shopkeeper-note t-caption muted">The assistant can propose; only you can approve and sign on Hedera testnet. Fair use: <%= Chat::UsageBudget.daily_visitor_messages %> messages per visitor each day.</p>
    </section>
  <% end %>
</section>

<% unless @catalog_definition %>
<div class="doors-grid" role="group" aria-label="Three ways to buy">
  <div class="door">
    <h2>Shop with AI</h2>
    <p class="t-small">Describe what you need. The shopkeeper searches through Printwright's
      real public API, shows every tool call, and prepares a bounded offer for your approval.</p>
  </div>
  <div class="door">
    <h2>Humans</h2>
    <p class="t-small">This storefront — the Buy button runs the same x402 negotiation, signed
      by a wallet instead of a script.</p>
  </div>
  <div class="door">
    <h2>Agents &amp; print servers</h2>
    <p class="t-small">REST + x402 over plain HTTP lets software pay a per-print royalty on
      Hedera and receive the file plus certificate. <%= link_to "API docs →", docs_path %></p>
  </div>
</div>

<section class="early-access-panel">
  <div>
    <h2>Design printable models?</h2>
    <p class="t-small muted">Join designer early access. One email when onboarding opens;
      no account, newsletter, or public profile is created.</p>
  </div>
  <%= form_with url: designer_early_access_path, class: "early-access-form" do %>
    <%= label_tag :email_address, "Designer email", class: "visually-hidden" %>
    <%= email_field_tag :email_address, nil, required: true, autocomplete: "email",
          placeholder: "designer@example.com", "aria-label": "Designer email" %>
    <%= submit_tag "Join early access", class: "btn btn-primary" %>
  <% end %>
</section>
<% end %>

<nav class="catalog-browse<%= " catalog-browse-compact" if @catalog_definition %>" aria-label="Browse the catalog">
  <div>
    <h2>Categories</h2>
    <div class="browse-grid">
      <% Model3d::CATEGORIES.each do |key, definition| %>
        <%= link_to category_path(key, anchor: "models"), class: "browse-card",
              "aria-current": (@category_key == key ? "page" : nil) do %>
          <strong><%= definition.fetch(:name) %></strong>
          <span><%= pluralize(@category_counts.fetch(key, 0), "model") %></span>
        <% end %>
      <% end %>
    </div>
  </div>
  <div>
    <h2>Collections</h2>
    <div class="browse-grid">
      <% Model3d::COLLECTIONS.each do |key, definition| %>
        <%= link_to collection_path(key, anchor: "models"), class: "browse-card",
              "aria-current": (@collection_key == key ? "page" : nil) do %>
          <strong><%= definition.fetch(:name) %></strong>
          <span><%= pluralize(@collection_counts.fetch(key, 0), "model") %></span>
        <% end %>
      <% end %>
    </div>
  </div>
</nav>

<% unless @catalog_definition %>
  <div class="steps-strip" role="group" aria-label="How a purchase works">
    <div class="step"><span class="step-num">1</span> Search the catalog</div>
    <div class="step"><span class="step-num">2</span> <span class="mono">402</span> payment required</div>
    <div class="step"><span class="step-num">3</span> Pay on Hedera (HBAR/USDC)</div>
    <div class="step"><span class="step-num">4</span> File + certificate, on-chain</div>
  </div>

  <div class="trust-strip t-small">
    <span>Testnet deployment — settlements are real Hedera testnet transactions with no monetary
      value.</span>
    <span><%= link_to "Verify a real certificate ↗", verify_path(cert_id: "pw-000038"), class: "mono" %></span>
  </div>
<% end %>

<section id="models" class="catalog-results" aria-labelledby="models_heading">
<div class="catalog-results-head">
  <div>
    <p class="eyebrow">Printable catalog</p>
    <h2 id="models_heading"><%= @query.present? ? "Results for “#{@query}”" : "Models" %></h2>
  </div>
  <% if @query.present? || params[:supports_free].present? || params[:material].present? || params[:max_price_cents].present? %>
    <%= link_to "Clear search and filters", root_path(anchor: "models"), class: "t-small" %>
  <% end %>
</div>

<div class="filters" role="group" aria-label="Filters">
  <%= link_to "Support-free",
        url_for(request.query_parameters.merge(supports_free: params[:supports_free].present? ? nil : "1").compact) + "#models",
        class: "pill", "aria-current": (params[:supports_free].present? ? "true" : nil) %>
  <%= link_to "PLA",
        url_for(request.query_parameters.merge(material: params[:material] == "PLA" ? nil : "PLA").compact) + "#models",
        class: "pill", "aria-current": (params[:material] == "PLA" ? "true" : nil) %>
  <%= link_to "≤ 3 USDC",
        url_for(request.query_parameters.merge(max_price_cents: params[:max_price_cents].present? ? nil : 300).compact) + "#models",
        class: "pill", "aria-current": (params[:max_price_cents].present? ? "true" : nil) %>
</div>

<% if @models.any? %>
  <div class="card-grid">
    <%= render partial: "model_card", collection: @models, as: :model %>
  </div>
<% else %>
  <div class="empty-state">
    <h2>No matches</h2>
    <p>Try <%= link_to "“beaver”", root_path(q: "beaver", anchor: "models") %> — or clear the filters.</p>
  </div>
<% end %>
</section>
