<% content_for :title, "#{@model.title} — Printwright" %>
<% content_for :head do %>
  <script type="application/ld+json">
    <%# json_escape: designer-supplied text must not be able to close the script tag;
        its output (unicode-escaped <, >, &) is safe to emit raw inside <script> %>
    <%== json_escape JSON.generate(
      "@context": "https://schema.org",
      "@type": "Product",
      name: @model.title,
      description: @model.description,
      sku: @model.slug,
      brand: { "@type": "Person", name: @model.designer.display_name },
      offers: @model.license_offers.map { |offer|
        { "@type": "Offer", price: format("%.2f", offer.price_cents / 100.0),
          priceCurrency: "USD",
          availability: offer.sold_out? ? "https://schema.org/OutOfStock" : "https://schema.org/InStock",
          name: "#{offer.kind.humanize} license",
          url: api_v1_model_download_url(model_id: @model.id, license: offer.kind),
          itemOffered: {
            "@type": "DigitalDocument",
            additionalType: "PrintLicense",
            name: "#{offer.kind.humanize} print license",
            license: offer.terms_version ?
              license_document_url(version: offer.terms_version, kind: offer.kind, format: :json) : nil
          }.compact }
      }
    ) %>
  </script>
<% end %>

<div class="model-page">
  <div class="model-main">
    <header class="model-head">
      <% if @model.category.present? %>
        <p class="card-taxonomy"><%= Model3d.category_definition(@model.category).fetch(:name) %></p>
      <% end %>
      <h1><%= @model.title %></h1>
      <p class="t-small muted">by <%= link_to @model.designer.display_name, designer_path(@model.designer) %><%= " ✓" if @model.designer.identity_verified? %></p>
    </header>

    <% preview_file = @model.preview_file %>
    <% render_files = @model.render_files.select { |file| file.file.attached? } %>
    <% render_file = render_files.first %>
    <div class="gallery model-preview" data-controller="model-preview"
         <% if preview_file&.file&.attached? %>
           data-model-preview-url-value="<%= rails_storage_proxy_path(preview_file.file) %>"
         <% end %>>
      <div class="model-preview-stage" data-model-preview-target="stage">
        <% if render_file&.file&.attached? %>
          <%= image_tag render_file.file, alt: @model.title, data: { model_preview_target: "fallback" } %>
        <% else %>
          <div class="model-preview-placeholder" data-model-preview-target="fallback">Preview render unavailable</div>
        <% end %>
      </div>
      <p class="t-caption muted model-preview-status" data-model-preview-target="status" aria-live="polite">
        <% if preview_file&.file&.attached? %>
          Loading a coarse, non-printable preview…
        <% else %>
          Interactive preview unavailable — showing the designer render.
        <% end %>
      </p>
      <% if render_files.many? %>
        <div class="turntable-thumbnails" aria-label="Turntable views">
          <% render_files.each_with_index do |file, index| %>
            <%= image_tag file.file, alt: "#{@model.title} view #{index + 1} of #{render_files.length}", loading: "lazy" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# The drawing-sheet title block. One of the two places in the system
        where a rule survives, because this is tabulated data. %>
    <dl class="title-block">
      <% @model.printability.each do |key, value| %>
        <div>
          <dt><%= printability_label(key) %></dt>
          <dd><%= printability_value(key, value) %></dd>
        </div>
      <% end %>
      <div>
        <dt>Licensed</dt>
        <dd><%= @licenses_issued %></dd>
      </div>
    </dl>

    <div class="trust-strip" data-controller="clipboard">
      <span>
        file hash
        <span class="mono" data-clipboard-target="source"><%= @model.file_hash&.truncate(24) %></span>
        <button class="copy-btn" type="button"
                data-action="clipboard#copy" data-clipboard-full-value="<%= @model.file_hash %>">copy</button>
      </span>
      <%# The licence count is already a cell in the title block below — one
          fact, one place. %>
      <% if @successful_prints.positive? %>
        <%# An attestation, not a settlement state — so a neutral badge, not
            one of the three status marks. %>
        <span class="badge print-tested-badge">
          Print-tested · <%= pluralize(@successful_prints, "paid holder report") %>
        </span>
        <span class="t-caption muted">Self-reported; not independently inspected</span>
      <% end %>
    </div>

    <div class="prose"><%= simple_format(@model.description) %></div>

    <% if @model.tags.any? %>
      <p class="t-small muted">Tags: <%= @model.tags.join(", ") %></p>
    <% end %>
  </div>

  <aside>
    <div class="buy-panel" data-controller="checkout"
         data-checkout-download-url-value="<%= "/api/v1/models/#{@model.id}/download" %>"
         <%# An explicit local signer is reserved for development/test. Customer
             checkout otherwise loads the connected-wallet module on demand. %>
         <% if (wallet_url = ENV["DEMO_WALLET_URL"].presence) %>data-checkout-wallet-url-value="<%= wallet_url %>"<% end %>>
      <h3>Buy a license</h3>
      <% @model.license_offers.each_with_index do |offer, index| %>
        <%# price-display carries the server-formatted price (ℏ · $ for HBAR-lead offers, live
            rate) so the controller can relabel the button without flattening it to bare USD. %>
        <label class="offer-row" data-checkout-target="offer" data-price-cents="<%= offer.price_cents %>"
               data-price-display="<%= offer_price(offer) %>">
          <input type="radio" name="license" value="<%= offer.kind %>" <%= "checked" if index.zero? %>
                 data-action="change->checkout#updatePrice">
          <span class="offer-copy">
            <strong><%= offer.kind.humanize %></strong>
            <span class="t-caption">
              <%= offer.kind == "personal" ? "print for yourself, unlimited copies" : "one licensed sale per unit" %>
            </span>
            <% if offer.max_units %>
              <span class="t-caption">
                <%= offer.units_remaining %> of <%= offer.max_units %> license slots available
              </span>
            <% end %>
          </span>
          <span class="price"><%= offer_price(offer) %></span>
        </label>
      <% end %>
      <% if @model.license_offers.any?(&:max_units) %>
        <p class="t-caption muted">A license issuance cap limits how many licenses Printwright
          will sell. It is not a claim of physical scarcity and does not technically prevent
          someone from making prints outside their license terms.</p>
      <% end %>
      <div class="offer-terms">
        <% @model.license_offers.each do |offer| %>
          <details class="t-small">
            <summary>License terms — <%= offer.kind.humanize.downcase %><%= " (#{offer.terms_version})" if offer.terms_version %></summary>
            <pre><%= offer.terms_text %></pre>
            <% if offer.terms_version %>
              <%= link_to "permalink + hash recipe", license_document_path(version: offer.terms_version, kind: offer.kind), class: "t-caption" %>
            <% end %>
          </details>
        <% end %>
      </div>
      <button class="btn btn-primary btn-block" type="button"
              data-checkout-target="button" data-action="checkout#buy">
        Buy license · <%= offer_price(@model.license_offers.first) %>
      </button>
      <div class="checkout-status" data-checkout-target="status" aria-live="polite" tabindex="-1"></div>
      <div data-checkout-target="receipt" hidden tabindex="-1"></div>
      <p class="t-caption muted">
        Pays via x402 on Hedera <%= Hedera::Network.name %> · HBAR or USDC.
        Your connected wallet signs only; the facilitator pays the network fee.
      </p>
    </div>
  </aside>
</div>
