<%= link_to model_page_path(model.slug), class: "model-card" do %>
  <% if (render_file = model.render_file)&.file&.attached? %>
    <%= image_tag render_file.file, alt: model.title, loading: "lazy", decoding: "async" %>
  <% else %>
    <div class="card-thumb"></div>
  <% end %>
  <div class="card-body">
    <% if model.category.present? %>
      <p class="card-taxonomy"><%= Model3d.category_definition(model.category).fetch(:name) %></p>
    <% end %>
    <h3 class="card-name"><%= model.title %></h3>
    <div class="t-small muted">by <%= model.designer.display_name %></div>
    <div class="card-price-row">
      <% if (offer = model.license_offers.min_by(&:price_cents)) %>
        <span class="price card-price"><%= offer_price(offer) %></span>
      <% end %>
      <% p = model.printability %>
      <span class="card-units">
        <%= [ p["est_print_minutes"] && "#{p['est_print_minutes']} min",
              p["materials"]&.first ].compact.join(" · ") %>
      </span>
    </div>
  </div>
<% end %>
