<%= link_to model_page_path(model.slug), class: "model-card" do %>
  <% if (render_file = model.render_file)&.file&.attached? %>
    <%= image_tag render_file.file, alt: model.title %>
  <% end %>
  <div class="card-body">
    <h3><%= model.title %></h3>
    <div class="t-small muted"><%= model.designer.display_name %></div>
    <% if model.category.present? %>
      <div class="t-caption card-taxonomy"><%= Model3d.category_definition(model.category).fetch(:name) %></div>
    <% end %>
    <div class="t-caption muted">
      <% p = model.printability %>
      <%= [ p["est_print_minutes"] && "#{p['est_print_minutes']} min",
            p["materials"]&.join("/"),
            p["supports"] == false ? "no supports" : nil ].compact.join(" · ") %>
    </div>
    <% if (offer = model.license_offers.min_by(&:price_cents)) %>
      <div class="card-price-row">
        <span class="price"><%= offer_price(offer) %></span>
        <span class="badge badge-kind"><%= offer.kind.humanize.downcase %></span>
      </div>
    <% end %>
  </div>
<% end %>
