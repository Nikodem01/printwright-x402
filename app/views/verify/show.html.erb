<% content_for :title, "Certificate #{@license.cert_id} — Printwright" %>
<% content_for :description, ERB::Util.html_escape("#{@license.cert_id}: #{@model.title} #{@license.purchase.license_offer.kind.humanize.downcase} verified on Hedera.") %>
<% content_for :social_image, verify_share_card_url(@license.verify_slug) %>
<% content_for :social_image_alt, ERB::Util.html_escape("Printwright license certificate #{@license.cert_id} for #{@model.title}") %>
<% if @check.state == :minting %>
  <% content_for :head do %><meta http-equiv="refresh" content="5"><% end %>
<% end %>

<%# Status is shape-first: the mark carries the state so it survives greyscale
    and every form of colour blindness, and the word next to it is mandatory.
    No tinted banner fill — the colour lives in the mark and the label. %>
<% state, state_word = case @check.state
     when :anchored then [ "settled", "Settled" ]
     when :mismatch then [ "void", "Mismatch" ]
     else [ "pending", @check.state == :sandbox ? "Sandbox" : "Pending" ]
   end %>

<div class="verify-page">
  <% case @check.state %>
  <% when :sandbox %>
    <div class="verify-banner banner-pending banner-sandbox">
      <%= render "shared/state", state: "pending", label: "Sandbox" %>
      <span>Simulation — not on Hedera. This certificate is stored on Printwright's local
        throwaway topic; no funds moved and no printable model was delivered.</span>
    </div>
  <% when :anchored %>
    <div class="verify-banner banner-ok">
      <%= render "shared/state", state: "settled", label: "Verified on Hedera" %>
      <span>Matches the on-chain record.</span>
    </div>
  <% when :minting %>
    <div class="verify-banner banner-pending">
      <%= render "shared/state", state: "pending", label: "Minting" %>
      <span>The certificate is being anchored to the Hedera Consensus Service. This page
        refreshes automatically — mirror-node lag is a few seconds.</span>
    </div>
  <% when :mismatch %>
    <div class="verify-banner banner-bad">
      <%= render "shared/state", state: "void", label: "Mismatch" %>
      <span>The on-chain record differs from the marketplace copy in
        <span class="mono"><%= @check.mismatched_keys.join(", ") %></span>. Both copies shown below.</span>
    </div>
  <% end %>

  <div class="cert-card">
    <div class="cert-top">
      <div>
        <span class="cert-eyebrow"><%= @license.purchase.sandbox? ? "Sandbox rehearsal certificate" : "License certificate" %></span>
        <%# The largest object on this page. Nothing outranks it. %>
        <p class="cert-id"><%= @license.cert_id %></p>
      </div>
      <%= render "shared/state", state: state, label: state_word %>
    </div>

    <div class="cert-model">
      <% if (render_file = @model.render_file)&.file&.attached? %>
        <%= image_tag render_file.file, alt: @model.title, class: "cert-thumb" %>
      <% end %>
      <div>
        <h2 class="cert-model-title"><%= link_to @model.title, model_page_path(@model.slug) %></h2>
        <div class="t-small muted">by <%= link_to @model.designer.display_name, designer_path(@model.designer) %></div>
      </div>
    </div>

    <%# The on-chain facts lead, at or above body size, in --chain. They are
        the product's differentiator, not chrome — the system this replaces
        set them two steps below body text in a footer link colour. %>
    <dl class="cert-facts">
      <% if @license.hcs_topic_id.present? %>
        <dt>Topic</dt>
        <dd class="mono chain">
          <a href="<%= Hedera::Network.hashscan_base %>/topic/<%= @license.hcs_topic_id %>"><%= @license.hcs_topic_id %></a>
        </dd>
      <% end %>
      <% if @license.hcs_sequence_number.present? %>
        <dt>Sequence</dt><dd class="mono chain"><%= @license.hcs_sequence_number %></dd>
      <% end %>
      <% if @check.consensus_timestamp.present? %>
        <dt>Consensus</dt><dd class="mono chain"><%= @check.consensus_timestamp %></dd>
      <% end %>
      <dt>Unit</dt>
      <dd class="mono">
        <%= @cert.present? ? @cert["unit_serial"] : @license.serial %> of
        <%= @license.purchase.license_offer.max_units || "unlimited" %> ·
        <%= @license.purchase.license_offer.kind.humanize.downcase %>
      </dd>

      <% if @cert.present? %>
        <dt>Issued</dt>
        <dd class="mono">
          <% if @check.consensus_timestamp %>
            <% issued_at = Time.at(@check.consensus_timestamp.to_r).utc %>
            <time datetime="<%= issued_at.iso8601(9) %>"><%= issued_at.strftime("%-d %B %Y, %H:%M UTC") %></time>
          <% elsif (issued_at = (Time.iso8601(@cert["issued_at"]) rescue nil)) %>
            <time datetime="<%= @cert["issued_at"] %>"><%= issued_at.utc.strftime("%-d %B %Y, %H:%M UTC") %></time>
          <% else %>
            <%= @cert["issued_at"] %>
          <% end %>
          <span class="fact-note"><%= @license.purchase.sandbox? ? "local sandbox time" : "network consensus time" %></span>
        </dd>
        <dt>Designer</dt>
        <dd>
          <span class="mono"><%= @cert["designer"] %></span>
          <% if @model.designer&.hedera_account_id.present? && @model.designer.hedera_account_id == @cert["designer"] %>
            — <%= link_to @model.designer.display_name, designer_path(@model.designer) %>
          <% end %>
        </dd>
        <dt>Buyer</dt><dd class="mono"><%= @cert["buyer_hint"] %></dd>
        <dt>Model hash</dt>
        <dd class="mono" data-controller="clipboard">
          <span data-clipboard-target="source"><%= @cert["model_hash"]&.truncate(28) %></span>
          <button class="copy-btn" type="button" data-action="clipboard#copy"
                  data-clipboard-full-value="<%= @cert["model_hash"] %>">copy</button>
        </dd>
        <dt>Terms hash</dt>
        <dd class="mono">
          <%= @cert["terms_hash"]&.truncate(28) %>
          <% offer = @license.purchase.license_offer %>
          <% if offer.terms_version && Licensing::Documents.hash(offer.terms_version, offer.kind) == @cert["terms_hash"] %>
            <%= link_to "read the licensed terms", license_document_path(version: offer.terms_version, kind: offer.kind), class: "t-small" %>
          <% else %>
            <span class="fact-note">hash of the offer's terms as they stood at purchase — the anchored hash is the contract</span>
          <% end %>
        </dd>
      <% end %>
    </dl>

    <% if @check.state == :mismatch %>
      <h3>Marketplace copy vs on-chain copy</h3>
      <%# Wide content scrolls inside its own box — the page body must never
          scroll sideways. %>
      <div class="table-scroll">
      <table class="facts-table">
        <tr><th>field</th><th>marketplace</th><th>on-chain</th></tr>
        <% (@check.onchain.keys | @license.cert_json.keys).each do |key| %>
          <tr class="<%= "mismatch-row" if @check.mismatched_keys.include?(key) %>">
            <th scope="row"><%= key %></th>
            <td class="mono"><%= @license.cert_json[key] %></td>
            <td class="mono"><%= @check.onchain[key] %></td>
          </tr>
        <% end %>
      </table>
      </div>
    <% end %>
  </div>

  <footer class="evidence-footer">
    <% unless @license.purchase.sandbox? %>
      <% if @cert&.dig("payment_tx").present? %>
      <a class="mono" href="<%= Hedera::Network.hashscan_base %>/transaction/<%= @cert["payment_tx"] %>">payment tx ↗</a>
      <% end %>
      <% if @license.hcs_topic_id.present? %>
      <a class="mono" href="<%= Hedera::Network.hashscan_base %>/topic/<%= @license.hcs_topic_id %>">HCS topic ↗</a>
      <% end %>
    <% end %>
    <% if @check.mirror_url.present? %>
      <a class="mono" href="<%= @check.mirror_url %>">raw mirror message ↗</a>
    <% end %>
    <% if @license.nft_serial.present? %>
      <dl class="cert-facts">
        <dt>License NFT</dt>
        <dd>
          <a class="mono" href="<%= Hedera::Network.hashscan_base %>/token/<%= @license.nft_token_id %>/<%= @license.nft_serial %>">
            <%= @license.nft_token_id %> · serial <%= @license.nft_serial %></a>
          <% state = @license.refresh_nft_claim_state! %>
          <span class="badge <%= state == "claimed" ? "badge-ok" : "badge-pending" %>"><%= state %></span>
          <% if state == "pending" %>
            <span class="t-caption muted">— airdropped, waiting for the buyer's wallet to claim it</span>
          <% end %>
        </dd>
      </dl>
    <% end %>
    <p class="t-small">
      <%= link_to(@license.purchase.sandbox? ? "Printable sandbox record" : "Printable certificate",
                  verify_certificate_path(@license.verify_slug)) %> ·
      <%= link_to "Share card", verify_share_card_path(@license.verify_slug) %> ·
      <%= link_to "Embeddable badge", badge_docs_path %>
    </p>
    <p class="t-caption muted">
      <% if @license.purchase.sandbox? %>
        Sandbox records imitate the public mirror envelope for integration rehearsal only. They
        are not consensus records, cannot prove payment, and never count as issued licenses.
      <% else %>
      How verification works: this page fetches the certificate from Hedera's public mirror node
      and compares it, field by field, with the marketplace record. The chain copy wins.
      Every licensed unit gets a certificate like this one — how many units of a model were ever
      licensed is public, auditable fact, not a marketplace claim.
      <% end %>
    </p>
  </footer>
</div>
