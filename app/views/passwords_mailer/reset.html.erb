<h1 style="margin:0 0 16px; color:#141916; font-size:26px; line-height:1.2;">Reset your password</h1>
<p style="margin:0 0 24px; color:#334155; font-size:16px; line-height:1.6;">
  We received a request to reset your Printwright designer password. Use the secure, one-time link below.
</p>
<p style="margin:0 0 24px;">
  <%= link_to "Reset password", edit_password_url(@password_reset_token),
    style: "display:inline-block; padding:13px 22px; border-radius:6px; background:#1B5E45; color:#ffffff; font-size:16px; font-weight:700; text-decoration:none;" %>
</p>
<p style="margin:0 0 8px; color:#64748b; font-size:13px; line-height:1.5;">
  This one-time link expires in <%= distance_of_time_in_words(0, @designer.password_reset_token_expires_in) %>.
</p>
<p style="margin:0; color:#64748b; font-size:13px; line-height:1.5; word-break:break-all;">
  Button not working? Paste this URL into your browser:<br>
  <%= link_to edit_password_url(@password_reset_token), edit_password_url(@password_reset_token), style: "color:#1B5E45;" %>
</p>
<p style="margin:24px 0 0; padding-top:16px; border-top:1px solid #e2e8f0; color:#64748b; font-size:13px; line-height:1.5;">
  If you did not request a password reset, you can ignore this email. Your password will not change.
</p>
