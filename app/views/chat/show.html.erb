<% content_for :title, "Ask the shopkeeper — Printwright" %>

<div class="chat-page">
  <h1>Ask the shopkeeper</h1>
  <p class="muted t-small">
    Search the catalog in conversation — the same public API any outside agent calls, so every
    answer traces back to a real tool call. Purchases require a separate human approval and settle
    on Hedera testnet.
  </p>

  <p class="chat-cap-banner t-small">
    <% if Chat::PurchasePolicy.enabled? %>
      <strong>Spend guard:</strong> at most <%= number_to_currency(@chat_spend_cap_cents / 100.0) %>
      per conversation, exact USDC only. Chat can prepare a proposal; only your button click can approve it.
    <% else %>
      <strong>Purchases are disabled.</strong> Catalog search remains available.
    <% end %>
  </p>

  <div id="chat_messages" class="chat-messages">
    <% if @turns.empty? %>
      <p id="chat_empty_state" class="empty-state t-small">
        Ask about a model — try “do you have anything to tidy the cables on my desk?”
      </p>
    <% end %>
    <%= render partial: "chat/turn", collection: @turns, as: :turn %>
  </div>

  <%= render "chat/purchase", proposal: @purchase_proposal %>

  <%= render "chat/form" %>
</div>
