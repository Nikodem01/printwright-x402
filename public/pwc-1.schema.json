{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Nikodem01/printwright-x402/main/public/pwc-1.schema.json",
  "title": "PWC-1 Print License Certificate",
  "description": "Version 1 of the compact certificate payload anchored as one Hedera Consensus Service message.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "v", "cert_id", "model_id", "model_hash", "designer", "license_type",
    "unit_serial", "buyer_hint", "payment_tx", "issued_at", "terms_hash"
  ],
  "properties": {
    "v": { "const": 1 },
    "cert_id": { "type": "string", "pattern": "^pw-[0-9]{6,}$" },
    "model_id": { "type": "integer", "minimum": 1 },
    "model_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "designer": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "license_type": { "type": "string", "enum": ["personal", "commercial_unit"] },
    "unit_serial": { "type": "integer", "minimum": 1 },
    "buyer_hint": {
      "type": "string",
      "pattern": "^(bearer|[0-9]+\\.[0-9]+\\.[0-9]+)$",
      "description": "A non-secret payer hint, not proof of current ownership."
    },
    "payment_tx": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+@[0-9]+\\.[0-9]{1,9}$"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "terms_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
