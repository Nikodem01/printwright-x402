# Copy to sidecar/.env and fill in locally. sidecar/.env is gitignored.
# Public Hedera/topic values and SIDECAR_TOKEN are loaded from the root .env
# first; this file keeps spending keys out of the Rails process.

HEDERA_PRIVATE_KEY=                  # operator ECDSA key: HCS messages and transaction fees

# Required by the production Kamal deployment for designer payouts/refunds.
# The treasury account can be the operator account, but keep the roles explicit.
TREASURY_ACCOUNT_ID=0.0.xxxxxxx
TREASURY_PRIVATE_KEY=
