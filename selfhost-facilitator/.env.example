# Fee-payer account: sponsors network fees and submits buyers' signed transfers.
# Must be a funded ECDSA account. Per the exact-Hedera scheme's fee-payer safety
# check it must NOT be the buyer or the payTo of any payment it settles.
HEDERA_ACCOUNT_ID=0.0.xxxxxxx
HEDERA_PRIVATE_KEY=            # ECDSA private key (0x-prefixed hex or DER)
HEDERA_NETWORK=testnet        # testnet | mainnet
PORT=4022
