# Copy to .env and fill in. .env is gitignored — never commit real keys.
# The Rails app never needs a private key; keys live only with the signers
# (sidecar/.env for the operator, your shell env for the buyer scripts).

# --- Hedera testnet operator (get one at https://portal.hedera.com/dashboard) ---
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.xxxxxxx
HEDERA_HCS_TOPIC_ID=                  # created once via the sidecar — see README "First-time setup"

# --- x402 payment settings ---
X402_FACILITATOR_URL=https://api.testnet.blocky402.com   # hosted facilitator (no key needed)
X402_PAY_TO=0.0.xxxxxxx               # treasury account receiving payments (must be USDC-associated)
X402_DEMO_HBAR_PRICE_CENTS=25         # fixed demo conversion: US cents per 1 HBAR

# --- HCS signing sidecar (the only operator-key holder) ---
HEDERA_SIDECAR_URL=http://localhost:4021
SIDECAR_TOKEN=change-me               # shared secret between Rails and the sidecar
SIDECAR_PORT=4021
# Put the operator key in sidecar/.env (NOT here):
#   HEDERA_PRIVATE_KEY=0x...          # hex-encoded ECDSA key (portal default)

# --- Mirror node (public, no key) ---
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# --- Demo designer payout accounts (optional) ---
# Funded testnet accounts for two seed designers; when set (and the account can
# receive USDC), their sales pay them directly instead of treasury custody.
# SEED_STUDIO_ACCOUNT_ID=0.0.xxxxxxx
# SEED_ATELIER_ACCOUNT_ID=0.0.xxxxxxx

# --- Buyer-side scripts (scripts/buy.mjs, scripts/demo-wallet.mjs, mcp/) ---
# Export these in your shell rather than storing them here, so the Rails
# process never loads a spending key:
#   BUYER_ACCOUNT_ID=0.0.xxxxxxx
#   BUYER_PRIVATE_KEY=0x...
#   MAX_SPEND_CENTS=500               # MCP buy_license guardrail
#   DEMO_WALLET_PORT=4022
