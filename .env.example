# Copy to .env and fill in. .env is gitignored (Rails default: /.env*).
# NEVER commit real keys. NEVER send the private key to the hosted Hedera MCP.

# --- Hedera testnet (get from https://portal.hedera.com/dashboard) ---
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.xxxxxxx
HEDERA_PRIVATE_KEY=0x...              # hex-encoded ECDSA key (portal default); never leaves local signers
HEDERA_HCS_TOPIC_ID=0.0.xxxxxxx       # license-certificate topic (create once)

# --- x402 facilitator (hosted Blocky402 testnet; self-hosted Node service is the fallback) ---
X402_FACILITATOR_URL=https://api.testnet.blocky402.com
X402_ASSET=USDC                       # or HBAR
X402_PAY_TO=0.0.xxxxxxx               # marketplace treasury account

# --- Hedera signing sidecar (local Node + @hashgraph/sdk) ---
HEDERA_SIDECAR_URL=http://localhost:4021

# --- LLM (shopkeeper chat + semantic search embeddings) ---
ANTHROPIC_API_KEY=sk-ant-...
